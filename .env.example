# ========================================
# PostgreSQL
# ========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password

# --- Auth Service DB ---
AUTH_DB_NAME=authdb
AUTH_DB_USER=auth_user
AUTH_DB_PASS=your_auth_db_password

# --- Course Service DB ---
COURSE_DB_NAME=coursedb
COURSE_DB_USER=course_user
COURSE_DB_PASS=your_course_db_password

# --- Enrollment Service DB ---
ENROLL_DB_NAME=enrolldb
ENROLL_DB_USER=enroll_user
ENROLL_DB_PASS=your_enroll_db_password

# --- Notification Service DB ---
NOTIFICATION_DB_NAME=notificationdb
NOTIFICATION_DB_USER=notification_user
NOTIFICATION_DB_PASS=your_notification_db_password

# ========================================
# RabbitMQ
# ========================================
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=your_rabbitmq_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# ========================================
# Service Ports
# ========================================
GATEWAY_PORT=8080
AUTH_PORT=8081
COURSE_PORT=8082
ENROLLMENT_PORT=8083
NOTIFICATION_PORT=8085
